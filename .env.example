# Copy to .env and adjust. py-forge expects you to supply your own Postgres.

# local | staging | production. /docs and /redoc are hidden outside local/staging.
ENVIRONMENT=local

# Must use the asyncpg driver. Create the database first: createdb py_forge
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/py_forge

# Set true to log all SQL.
DB_ECHO=false

# Comma-separated list, or "*" for all (dev only).
CORS_ORIGINS=*

# --- Auth domain (AUTH_ prefix) ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_JWT_ALG=HS256
AUTH_JWT_ACCESS_EXP_MINUTES=15
AUTH_REFRESH_TOKEN_EXP_DAYS=30

# --- Seed script (scripts/seed.py) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# --- Object storage / S3 (S3_ prefix) ---
# Works with AWS S3 or any S3-compatible store (MinIO, Cloudflare R2, LocalStack).
S3_BUCKET=py-forge
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_REGION=us-east-1
# Set for S3-compatible stores, e.g. MinIO: http://localhost:9000. Leave unset for AWS.
# S3_ENDPOINT_URL=http://localhost:9000
# Public origin (CDN or public bucket) used to resolve a stored key to a URL.
# S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_USE_SSL=true
S3_PRESIGN_EXPIRY_SECONDS=3600
